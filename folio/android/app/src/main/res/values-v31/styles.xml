<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (API 31) SplashScreen API overrides — light mode -->
<resources>
    <style name="LaunchTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Solid background color for the SplashScreen API (light) -->
        <item name="android:windowSplashScreenBackground">#FAFFF0</item>
        <!-- The animated / static icon shown in the center -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash</item>
        <!-- Keep the same window background for the transition -->
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>
</resources>
